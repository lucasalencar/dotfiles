#!/bin/bash

# Clears the macOS notification for the current tmux window.
# Used automatically via after-select-window hook in .tmux.conf.

[ "$(uname)" != "Darwin" ] && exit 0

GROUP_ID=$(tmux display-message -p "tmux-window-#{session_name}-#I" 2>/dev/null)
[ -n "$GROUP_ID" ] && /opt/homebrew/bin/terminal-notifier -remove "$GROUP_ID" >/dev/null 2>&1
