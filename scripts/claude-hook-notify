#!/bin/bash
INPUT=$(cat)
TYPE=$(echo "$INPUT" | jq -r .notification_type)

[ "$TYPE" = "auth_success" ] && exit 0

MSG=$(echo "$INPUT" | jq -r ".message // empty")
[ -z "$MSG" ] && exit 0

WIN=$(tmux display-message -t "$TMUX_PANE" -p "#I" 2>/dev/null)

# Skip notification if kitty is focused and the Claude pane is in the active tmux window
IS_KITTY=$(osascript -e 'tell application "System Events" to frontmost of application process "kitty"' 2>/dev/null)
if [ "$IS_KITTY" = "true" ]; then
  CLAUDE_WIN=$(tmux display-message -t "$TMUX_PANE" -p "#{session_name}:#{window_index}" 2>/dev/null)
  ACTIVE_WIN=$(tmux display-message -p "#{session_name}:#{window_index}" 2>/dev/null)
  [ -n "$CLAUDE_WIN" ] && [ "$CLAUDE_WIN" = "$ACTIVE_WIN" ] && exit 0
fi

PROJECT=$(basename "$PWD")
notify-macos "Claude Code - $PROJECT" "$MSG" "tmux select-window -t $WIN" "tmux-window-$WIN" &
