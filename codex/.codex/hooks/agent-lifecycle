#!/usr/bin/env bash

set -u

action="${1:-}"
payload=$(cat)

set_agent_state() {
  command -v tmux-agent-state >/dev/null 2>&1 || return 0
  tmux-agent-state "$1" "Codex" >/dev/null 2>&1 || true
}

mark_window() {
  command -v tmux-notify-window >/dev/null 2>&1 || return 0
  tmux-notify-window >/dev/null 2>&1 || true
}

notify_agent() {
  command -v agent-notify >/dev/null 2>&1 || return 0
  printf '%s' "$payload" | agent-notify "Codex" "$1" >/dev/null 2>&1 || true
}

auto_review_enabled() {
  local config_file="${CODEX_HOME:-$HOME/.codex}/config.toml"

  [ -r "$config_file" ] || return 1

  awk '
    /^[[:space:]]*\[/ { exit }
    /^[[:space:]]*approvals_reviewer[[:space:]]*=/ {
      value = $0
      sub(/^[^=]*=[[:space:]]*/, "", value)
      sub(/[[:space:]]*(#.*)?$/, "", value)
      if (value == "\"auto_review\"" || value == sprintf("%cauto_review%c", 39, 39)) {
        enabled = 1
      }
    }
    END { exit enabled ? 0 : 1 }
  ' "$config_file"
}

case "$action" in
  running)
    set_agent_state running
    ;;
  waiting-question)
    set_agent_state waiting
    mark_window
    notify_agent "asked a question"
    ;;
  waiting-permission)
    set_agent_state waiting
    mark_window
    if ! auto_review_enabled; then
      notify_agent "waiting for your input"
    fi
    ;;
  idle)
    set_agent_state idle
    mark_window
    notify_agent "done"
    ;;
  *)
    printf 'agent-lifecycle: unknown action: %s\n' "$action" >&2
    exit 2
    ;;
esac
