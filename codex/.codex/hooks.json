{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.codex/hooks/agent-lifecycle\" running",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(request_user_input|AskUserQuestion)$",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.codex/hooks/agent-lifecycle\" waiting-question",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.codex/hooks/agent-lifecycle\" waiting-permission",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.codex/hooks/agent-lifecycle\" running",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.codex/hooks/clojure-lint\"",
            "timeout": 600,
            "statusMessage": "Linting Clojure changes"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.codex/hooks/agent-lifecycle\" idle",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
