{
  "$schema": "https://opencode.ai/config.json",

  "plugin": [
    "{HOME}/.dotfiles/opencode/.config/opencode/plugins/notification.ts"
  ],

  "keybinds": {
    "input_newline": "Shift+Enter"
  },

  "autoshare": false,
  "autoupdate": true,

  "mcp": {
    "tmux": {
      "type": "local",
      "command": ["npx", "-y", "--registry=https://registry.npmjs.org/", "tmux-mcp", "--shell-type=zsh"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp/oauth",
      "enabled": true
    }
  }
}
