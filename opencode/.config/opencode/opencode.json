{
  "$schema": "https://opencode.ai/config.json",
  "theme": "monokai",
  "model": "anthropic/claude-sonnet-4-5", // Default model

  "mcp": {
    "atlassian": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.atlassian.com/v1/sse"
      ],
      "enabled": true
    },
    "slack": {
      "type": "local",
      "command": ["{env:HOME}//dev/nu/slack-mcp-server/start.sh"],
      "enabled": true
    }
  },

  "plugin": [
    "{HOME}/.dotfiles/opencode/.config/opencode/plugins/notification.ts"
  ],

  "lsp": {
    "clojure-lsp": {
      "command": ["clojure-lsp", "--stdio"],
      "extensions": [".clj", ".cljs", ".cljc"]
    }
  },

  "keybinds": {
    "input_newline": "Shift+Enter"
  },

  "autoshare": false,
  "autoupdate": true
}
