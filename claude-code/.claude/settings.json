{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "tmux-notify-window"
          },
          {
            "type": "command",
            "command": "agent-notify 'Claude Code' 'asked a question'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "tmux-notify-window"
          },
          {
            "type": "command",
            "command": "agent-notify 'Claude Code'"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "tmux-notify-window"
          },
          {
            "type": "command",
            "command": "agent-notify 'Claude Code'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux-notify-window"
          },
          {
            "type": "command",
            "command": "agent-notify 'Claude Code' 'done'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*.clj",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'lein lint-fix 2>&1 | lein lint 2>&1 | tail -20'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/lucas.alencar/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "slack@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "glean-mcp@nubank-ai-agents-plugins": true,
    "actions-eng-management@nubank-ai-agents-plugins": true,
    "tmux-agent-sidebar@hiroppy": true
  },
  "extraKnownMarketplaces": {
    "nubank-ai-agents-plugins": {
      "source": {
        "source": "github",
        "repo": "nubank/ai-agents-plugins"
      },
      "autoUpdate": true
    },
    "hiroppy": {
      "source": {
        "source": "directory",
        "path": "/Users/lucas.alencar/.tmux/plugins/tmux-agent-sidebar"
      },
      "autoUpdate": true
    }
  },
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto"
}
