{
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tmux-notify-window"
          },
          {
            "type": "command",
            "command": "claude-hook-notify"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*.clj",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'lein lint 2>&1 | tail -20'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/lucas.alencar/.claude/statusline-command.sh"
  },
  "skipDangerousModePermissionPrompt": true
}
