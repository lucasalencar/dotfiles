{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "model": "sonnet[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "tmux-notify-window"
          },
          {
            "type": "command",
            "command": "agent-notify 'Claude Code' 'asked a question'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "tmux-notify-window"
          },
          {
            "type": "command",
            "command": "agent-notify 'Claude Code'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux-notify-window"
          },
          {
            "type": "command",
            "command": "agent-notify 'Claude Code' 'done'"
          },
          {
            "type": "command",
            "command": "cp -f ~/.claude/settings.json ~/.dotfiles/claude-code/.claude/settings.json"
          },
          {
            "type": "command",
            "command": "cp -f ~/.claude/.mcp.json ~/.dotfiles/claude-code/.claude/.mcp.json 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*.clj",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'lein lint-fix 2>&1 | lein lint 2>&1 | tail -20'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/lucas.alencar/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "slack@claude-plugins-official": true,
    "glean-mcp@nubank-ai-agents-plugins": true,
    "actions-eng-management@nubank-ai-agents-plugins": true,
    "tmux-agent-sidebar@hiroppy": true,
    "isa@nubank-ai-agents-plugins": true,
    "pyright-lsp@claude-plugins-official": true,
    "isa@nubank-ai-agents-plugins-tmp": true,
    "isa@nubank-ai-agents-plugins-eng": true
  },
  "extraKnownMarketplaces": {
    "nubank-ai-agents-plugins": {
      "source": {
        "source": "git",
        "url": "git@github.com:nubank/ai-agents-plugins.git"
      },
      "autoUpdate": true
    },
    "hiroppy": {
      "source": {
        "source": "directory",
        "path": "/Users/lucas.alencar/.tmux/plugins/tmux-agent-sidebar"
      },
      "autoUpdate": true
    },
    "nubank-ai-agents-plugins-tmp": {
      "source": {
        "source": "git",
        "url": "git@github.com:nubank/ai-agents-plugins-tmp.git"
      }
    },
    "nubank-ai-agents-plugins-eng": {
      "source": {
        "source": "git",
        "url": "git@github.com:nubank/ai-agents-plugins-eng.git"
      }
    },
    "nubank-ai-agents-plugins-product": {
      "source": {
        "source": "git",
        "url": "git@github.com:nubank/ai-agents-plugins-product.git"
      }
    },
    "nubank-ai-agents-plugins-analytics": {
      "source": {
        "source": "git",
        "url": "git@github.com:nubank/ai-agents-plugins-analytics.git"
      }
    }
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto"
}
