#!/usr/bin/env bash
# tmux-agent-state: writer compartilhado do status por-pane de coding agents.
# Seta @pane_status (lido por tmux-agent-icon/tmux-agent-status) no pane do agente,
# resolvido via $TMUX_PANE. Agente-agnóstico: chamado pelos hooks do Claude Code e
# pelo plugin de notificação do OpenCode.
#
# Usage: tmux-agent-state <running|waiting|idle|error|clear> [agent_name]
#   running -> ● ; waiting -> ◐ ; error -> ✕ ; idle -> ○ ; clear -> remove o ícone
#
# O status permanece até ser explicitamente alterado ou limpo.
# Apenas a notificação (@notify) é limpa quando a janela está ativa.

set -u
[ -z "${TMUX:-}" ] && exit 0

state="${1:?usage: tmux-agent-state <running|waiting|idle|error|clear> [agent_name]}"
agent_name="${2:-}"

# Resolve o pane onde este agente está rodando.
pane="${TMUX_PANE:-}"
[ -z "$pane" ] && pane=$(tmux display-message -p '#{pane_id}' 2>/dev/null)
[ -z "$pane" ] && exit 0

# A janela do agente é a que está em foco?
win=$(tmux display-message -t "$pane" -p '#{window_id}' 2>/dev/null)
active_win=$(tmux display-message -p '#{window_id}' 2>/dev/null)
is_active=0
[ -n "$win" ] && [ "$win" = "$active_win" ] && is_active=1

case "$state" in
  running|waiting|idle|error)
    tmux set -p -t "$pane" @pane_status "$state"
    ;;
  clear)
    tmux set -p -t "$pane" @pane_status ""
    ;;
  *)
    exit 0
    ;;
esac

# Metadados para a listagem agregada (tmux-agent-status): barato e à prova de futuro.
[ -n "$agent_name" ] && tmux set -p -t "$pane" @pane_name "$agent_name"
cwd=$(tmux display-message -t "$pane" -p '#{pane_current_path}' 2>/dev/null)
[ -n "$cwd" ] && tmux set -p -t "$pane" @pane_cwd "$cwd"

tmux refresh-client -S 2>/dev/null || true
