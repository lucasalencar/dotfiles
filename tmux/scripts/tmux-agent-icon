#!/usr/bin/env bash
# Outputs one status icon per agent pane in a window.
# Usage: tmux-agent-icon <window_id>

icons=""
while IFS= read -r pane_id; do
  status=$(tmux show -t "$pane_id" -pv @pane_status 2>/dev/null)
  case "$status" in
    running)    icons="${icons}●" ;;
    waiting)    icons="${icons}◐" ;;
    error)      icons="${icons}✕" ;;
    background) icons="${icons}⚙" ;;
    idle)       icons="${icons}○" ;;
  esac
done < <(tmux list-panes -t "$1" -F '#{pane_id}')

[ -n "$icons" ] && echo " $icons"
