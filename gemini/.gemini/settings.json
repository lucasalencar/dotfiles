{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "general": {
    "vimMode": false,
    "previewFeatures": false,
    "preferredEditor": "neovim",
    "checkpointing": {
      "enabled": true
    }
  },
  "output": {
    "format": "text"
  },
  "ui": {
    "theme": "Dracula",
    "showStatusInTitle": false,
    "footer": {
      "hideContextPercentage": false
    },
    "showMemoryUsage": true
  },
  "tools": {
    "autoAccept": false,
    "useRipgrep": true
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "ToolPermission",
        "hooks": [
          {
            "name": "tmux-notify",
            "type": "command",
            "command": "bash -c 'tmux-notify-window; echo \"{}\"'"
          },
          {
            "name": "agent-notify",
            "type": "command",
            "command": "bash -c 'agent-notify; echo \"{}\"'"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "agent-notify",
            "type": "command",
            "command": "bash -c 'echo \"{\\\"notification_type\\\":\\\"done\\\",\\\"message\\\":\\\"Task finished\\\"}\" | agent-notify; echo \"{}\"'"
          }
        ]
      }
    ]
  }
}