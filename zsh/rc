#!/bin/bash

# ZINIT package manager
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
[ ! -d $ZINIT_HOME ] && mkdir -p "$(dirname $ZINIT_HOME)"
[ ! -d $ZINIT_HOME/.git ] && git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
source "${ZINIT_HOME}/zinit.zsh"

autoload -Uz _zinit
(( ${+_comps} )) && _comps[zinit]=_zinit

# --- Synchronous (needed before first prompt) ---

# Theme
zinit ice depth=1; zinit light romkatv/powerlevel10k

# OMZ libs that affect immediate shell behavior (history options, keybindings,
# directory aliases). Kept synchronous because they're tiny and useful from
# the very first prompt.
zinit snippet OMZL::history.zsh
zinit snippet OMZL::key-bindings.zsh
zinit snippet OMZL::directories.zsh

# Syntax highlight — kept synchronous because it hooks ZLE on every keystroke.
# Deferring it caused noticeable input lag when typing right after the prompt
# appeared (the plugin loaded mid-keystroke and froze input). Cost: ~50-80ms.
zinit light zdharma-continuum/fast-syntax-highlighting

# Load completions. Regenerate the dump at most once per day; on every other
# startup, use the cached dump (-C) to skip the full scan (saves ~100-300ms).
autoload -Uz compinit
if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi

# --- Deferred (loaded after first prompt via `zinit wait`) ---
# Saves ~150-400ms before prompt. Loads are STAGGERED to avoid blocking input
# while you start typing — without staggering, all plugins fire at once and
# zsh (single-threaded) freezes the prompt for the duration of all loads.
#
# Wait values: `'0a'`, `'0b'` etc. share the "next loop after prompt" slot but
# letters force ordering. Larger numbers are seconds after prompt.

# Git aliases + colored man pages (only matter when you run `git ...`/`man`)
zinit wait'1' lucid for \
  OMZP::git \
  OMZP::colored-man-pages

# git-fzf | gfzf | gf — only used via explicit invocation
zinit wait'1' lucid light-mode for alexiszamanidis/zsh-git-fzf

# Extra completions and fzf-tab last. `atload"zicompinit; zicdreplay"` re-runs
# compinit so completions added by deferred plugins get picked up.
zinit wait'2' lucid light-mode for zsh-users/zsh-completions
zinit wait'2' lucid light-mode \
  atload"zicompinit; zicdreplay" \
  for Aloxaf/fzf-tab

# Completions setup
zstyle ':completion:*' menu no # Disable default zsh completion menu
zstyle ':completion:*' matcher-list 'm:{[:lower:][:upper:]}={[:upper:][:lower:]}' 'r:|=*' 'l:|=* r:|=*' # case insensitive
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}" # Use LS_COLORS for completion colors
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color $realpath' # Show directory content when completing cd

# Completion for kitty. Cached on disk to avoid spawning kitty on every shell.
# Regenerate with: rm "${XDG_CACHE_HOME:-$HOME/.cache}/kitty-completion.zsh"
if (( $+commands[kitty] )); then
  kitty_comp="${XDG_CACHE_HOME:-$HOME/.cache}/kitty-completion.zsh"
  [[ -f $kitty_comp ]] || kitty + complete setup zsh > $kitty_comp
  source $kitty_comp
  unset kitty_comp
fi

# Load all custom configs from dotfiles to zsh
for file in $DOTFILES_ROOT/zsh/*.zsh; do
  source $file
done
